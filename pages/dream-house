<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Savannah House Model</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=DM+Sans:wght@300;400;500;600&family=DM+Mono:wght@400;500&display=swap');

:root {
  --ink:     #1A1714;
  --bg:      #F5F0E8;
  --paper:   #FDFAF4;
  --muted:   #7A7168;
  --rule:    #DDD8CE;
  --amber:   #C4763A;
  --green:   #3A7A5C;
  --red:     #A03030;
  --blue:    #3A5C8A;
  --radius:  4px;
}

* { box-sizing: border-box; margin: 0; padding: 0; }

body {
  background: var(--bg);
  color: var(--ink);
  font-family: 'DM Sans', sans-serif;
  font-size: 14px;
  line-height: 1.6;
  padding: 28px 18px 60px;
  max-width: 820px;
  margin: 0 auto;
}

header {
  border-bottom: 2px solid var(--ink);
  padding-bottom: 16px;
  margin-bottom: 28px;
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  flex-wrap: wrap;
  gap: 10px;
}

header h1 {
  font-family: 'Playfair Display', serif;
  font-size: 2rem;
  line-height: 1.1;
  letter-spacing: -0.02em;
}

header h1 em { font-style: italic; color: var(--amber); }

.header-meta {
  font-family: 'DM Mono', monospace;
  font-size: 10px;
  color: var(--muted);
  text-align: right;
  line-height: 1.9;
  letter-spacing: 0.04em;
}

.sec-label {
  font-family: 'DM Mono', monospace;
  font-size: 10px;
  font-weight: 500;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--muted);
  border-bottom: 1px solid var(--rule);
  padding-bottom: 5px;
  margin-bottom: 14px;
}

section { margin-bottom: 36px; }

/* SCENARIO TABS */
.tabs {
  display: flex;
  gap: 6px;
  margin-bottom: 16px;
  flex-wrap: wrap;
}

.tab {
  padding: 6px 14px;
  border-radius: 20px;
  font-size: 12px;
  font-weight: 500;
  cursor: pointer;
  border: 1px solid var(--rule);
  background: var(--paper);
  color: var(--muted);
  transition: all 0.15s;
  font-family: 'DM Mono', monospace;
  letter-spacing: 0.03em;
}

.tab.active {
  background: var(--ink);
  color: var(--bg);
  border-color: var(--ink);
}

/* SCENARIO PANEL */
.scenario { display: none; }
.scenario.active { display: block; }

/* ASSUMPTION PILLS */
.pills {
  display: flex;
  flex-wrap: wrap;
  gap: 7px;
  margin-bottom: 18px;
}

.pill {
  background: var(--paper);
  border: 1px solid var(--rule);
  border-radius: 20px;
  padding: 3px 11px;
  font-size: 11px;
  color: var(--muted);
}

.pill strong { color: var(--ink); font-weight: 600; }

/* MAIN GRID */
.main-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 10px;
  margin-bottom: 10px;
}

@media (max-width: 560px) { .main-grid { grid-template-columns: 1fr; } }

/* CARDS */
.card {
  background: var(--paper);
  border: 1px solid var(--rule);
  border-radius: var(--radius);
  padding: 16px;
}

.card-title {
  font-family: 'DM Mono', monospace;
  font-size: 10px;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--muted);
  margin-bottom: 10px;
}

.flow-row {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  padding: 3px 0;
  border-bottom: 1px solid #EDEAE3;
  font-size: 12px;
}

.flow-row:last-of-type { border-bottom: none; }
.flow-row .lbl { color: var(--muted); font-size: 11px; }
.flow-row .amt {
  font-family: 'DM Mono', monospace;
  font-size: 12px;
  font-weight: 500;
}

.divrow {
  border-top: 1px solid var(--ink);
  margin-top: 7px;
  padding-top: 7px;
  display: flex;
  justify-content: space-between;
  align-items: baseline;
}

.divrow .lbl { font-weight: 600; font-size: 13px; }
.divrow .amt {
  font-family: 'DM Mono', monospace;
  font-size: 15px;
  font-weight: 700;
}

.green  { color: var(--green); }
.red    { color: var(--red); }
.amber  { color: var(--amber); }
.blue   { color: var(--blue); }
.muted  { color: var(--muted); }

/* BIG NUMBER */
.big-card {
  background: var(--ink);
  color: var(--bg);
  border-radius: var(--radius);
  padding: 20px;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.big-label {
  font-family: 'DM Mono', monospace;
  font-size: 10px;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  opacity: 0.5;
  margin-bottom: 4px;
}

.big-number {
  font-family: 'Playfair Display', serif;
  font-size: 2.2rem;
  line-height: 1;
  font-weight: 700;
  margin-bottom: 6px;
}

.big-number.positive { color: #7FD4A8; }
.big-number.negative { color: #E87878; }
.big-number.neutral  { color: #F5C87A; }

.big-sub {
  font-size: 11px;
  opacity: 0.6;
  line-height: 1.4;
}

/* YEAR TABS for Airbnb scenarios */
.mode-row {
  display: flex;
  gap: 8px;
  margin-bottom: 14px;
  flex-wrap: wrap;
}

.mode-btn {
  padding: 5px 13px;
  border-radius: 4px;
  font-size: 11px;
  font-weight: 600;
  cursor: pointer;
  border: 1px solid var(--rule);
  background: var(--paper);
  color: var(--muted);
  font-family: 'DM Mono', monospace;
  transition: all 0.15s;
}

.mode-btn.active {
  background: var(--amber);
  color: white;
  border-color: var(--amber);
}

.mode-panel { display: none; }
.mode-panel.active { display: block; }

/* EQUITY TIMELINE */
.equity-table {
  width: 100%;
  border-collapse: separate;
  border-spacing: 0;
  font-size: 12px;
  background: var(--paper);
  border: 1px solid var(--rule);
  border-radius: var(--radius);
  overflow: hidden;
}

.equity-table th {
  background: var(--ink);
  color: var(--bg);
  font-family: 'DM Mono', monospace;
  font-size: 10px;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  padding: 8px 12px;
  text-align: right;
  font-weight: 500;
}

.equity-table th:first-child { text-align: left; }

.equity-table td {
  padding: 8px 12px;
  border-bottom: 1px solid var(--rule);
  text-align: right;
  font-family: 'DM Mono', monospace;
  font-size: 11px;
  vertical-align: middle;
}

.equity-table td:first-child {
  text-align: left;
  font-family: 'DM Sans', sans-serif;
  font-weight: 500;
  font-size: 12px;
}

.equity-table tr:last-child td { border-bottom: none; }

.equity-table tr.highlight td {
  background: #F0EBE0;
  font-weight: 600;
}

.bar-cell { width: 100px; }

.mini-bar {
  height: 6px;
  background: var(--rule);
  border-radius: 3px;
  overflow: hidden;
  display: inline-block;
  width: 80px;
  vertical-align: middle;
}

.mini-fill {
  height: 100%;
  border-radius: 3px;
  background: var(--amber);
}

/* CAUTION */
.note {
  background: #FEF8F1;
  border-left: 3px solid var(--amber);
  padding: 12px 14px;
  border-radius: 0 var(--radius) var(--radius) 0;
  margin-top: 12px;
  font-size: 12px;
  color: var(--muted);
  line-height: 1.6;
}

.note strong { color: var(--ink); }
.note p + p { margin-top: 6px; }

/* VERDICT */
.verdict {
  background: var(--green);
  color: white;
  border-radius: var(--radius);
  padding: 18px 20px;
  margin-top: 14px;
}

.verdict-title {
  font-family: 'Playfair Display', serif;
  font-size: 1.15rem;
  font-weight: 700;
  margin-bottom: 6px;
}

.verdict p { font-size: 12px; opacity: 0.9; line-height: 1.6; }
</style>
</head>
